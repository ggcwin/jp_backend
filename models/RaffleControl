const mongoose = require('mongoose');

const raffleControlSchema = new mongoose.Schema({
    raffleDate: { type: Date, required: true, unique: true },
    manualNumbers: {
        first: { type: String, default: null },
        second: { type: String, default: null },
        third: { type: String, default: null }
    },
    isExecuted: { type: Boolean, default: false }
});

module.exports = mongoose.model('RaffleControl', raffleControlSchema);